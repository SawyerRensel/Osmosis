{
	"name": "osmosis",
	"version": "0.1.0",
	"description": "Obsidian plugin that unifies mind mapping, linked note-taking, and spaced repetition into a single learning system.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"e2e": "npm run build && npx playwright test",
		"e2e:setup": "bash e2e-setup.sh",
		"e2e:launch": "bash e2e-launch.sh"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@playwright/test": "^1.58.2",
		"@types/node": "^22.19.13",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^28.1.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
